{
  "deployment_fqdn": "<deployment_fqdn>",
  "deployment_id": "enterprise-ingress",
  "dns_zone_name": null,
  "dns_zone_resource_group_name": null,
  "enabled_log_categories": [
    "ApplicationGatewayAccessLog",
    "ApplicationGatewayFirewallLog",
    "ApplicationGatewayPerformanceLog"
  ],
  "ingress_private_ip": "10.5.255.254",
  "log_retention": 90,
  "routing_rules": [
    {
      "frontend_port": 443,
      "name": "web-adaptor",
      "priority": 10,
      "protocol": "Https",
      "rules": [
        {
          "name": "server",
          "backend_pool": "enterprise-base",          
          "backend_port": 6443,
          "backend_path": "/arcgis/",
          "override_host": true,
          "paths": [
            "/server",
            "/server/*"
          ],
          "probe": "/arcgis/rest/info/healthcheck",
          "request_timeout": 600
        },
        {
          "name": "portal",
          "backend_pool": "enterprise-base",
          "backend_port": 7443,
          "backend_path": "/arcgis/",
          "override_host": true,
          "paths": [
            "/portal",
            "/portal/*"
          ],
          "probe": "/arcgis/portaladmin/healthCheck",
          "request_timeout": 60
        },
        {
          "name": "notebooks",
          "backend_pool": "notebook-server",
          "backend_port": 443,
          "override_host": false,
          "paths": [
            "/notebooks",
            "/notebooks/*"
          ],
          "probe": "/notebooks/rest/info/healthcheck",
          "request_timeout": 60
        }
      ]
    }
  ],
  "site_id": "arcgis",
  "ssl_certificate_secret_id": "<ssl_certificate_secret_id>",
  "ssl_policy": "AppGwSslPolicy20220101",
  "subnet_id": null,
  "waf_mode": "detect",
  "zones": [
    "1",
    "2"
  ]
}
